<div class="farkle-drop-zone">
    <p>{{localize 'FARKLE.loadDiceDescription'}}</p>
    {{#if item}}
    <div class="farkle-flexrow" style="margin-bottom: 10px; padding: 10px; border: 2px solid var(--color-border-dark); border-radius: 5px;">
        <div class="farkle-flex0">
            <img src="{{item.img}}" style="height:60px;min-width:60px;object-fit:contain"/>
        </div>
        <div class="farkle-flex1" style="padding-left: 10px;">
            <b>{{item.name}}</b>            
        </div>
    </div>
    <p><b>{{localize 'FARKLE.setWeight'}}:</b></p>
    <div class="flexcol">
        {{#each sides as |side|}}
        <div class="farkle-flexrow">
            <div class="farkleDie farkle-flex0 {{side.cssClass}}">
                {{side.index}}
            </div>
            <input type="number" class="load" step="1" min="1" value="{{side.weight}}" data-index="{{side.index}}"/>
            <div class="probability">
                {{side.probability}}&nbsp;%
            </div>
        </div>
        {{/each}}
    </div>
    <div class="farkle-flexrow" style="margin-top:20px">
        <button type="button" data-action="loadDice"><i class="fas fa-check"></i> {{localize 'FARKLE.loadDice'}}</button>
        <button type="button" data-action="clearLoaded"><i class="icon fas fa-xmark"></i> {{localize 'FARKLE.reset'}}</button>
    </div>
    {{else}}
    <div style="padding: 20px; text-align: center; border: 2px dashed var(--color-border-dark); border-radius: 5px; margin-top: 10px;">
        <i class="fas fa-dice fa-3x" style="color: var(--color-text-dark-secondary); margin-bottom: 10px;"></i>
        <p style="font-size: 14px; color: var(--color-text-dark-secondary);">
            <b>{{localize 'FARKLE.dragItemHere'}}</b>
        </p>
        <p style="font-size: 12px; color: var(--color-text-dark-secondary);">
            {{localize 'FARKLE.dragItemInstructions'}}
        </p>
    </div>
    {{/if}}
    
</div>
